# ── HCC API (control-plane) ──────────────────────────────────────────────
# URL API HCC. Saat dijalankan di tempat teman, arahkan ke API lokal dia.
# Contoh: http://localhost:8000  atau  http://192.168.1.20:8000
HCC_API_URL=http://localhost:8000

# API key yang dikirim sebagai header X-API-Key ke API HCC.
# Nilai ini HANYA dipakai di server (proxy), tidak pernah bocor ke browser.
HCC_API_KEY=hcc_Api2026_devkey_change_me

# ── Mode demo ────────────────────────────────────────────────────────────
# Jika API tidak dapat dihubungi, dashboard otomatis memakai data demo (mock)
# supaya tetap bisa dilihat/didemokan. Set "false" untuk mematikan fallback
# (saat API asli sudah pasti tersedia di tempat teman).
HCC_DEMO_FALLBACK=true

# ── Login dashboard (statis, demo) ───────────────────────────────────────
# Kredensial untuk masuk ke dashboard. Ganti untuk produksi.
DASHBOARD_USER=admin
DASHBOARD_PASS=pln2026
